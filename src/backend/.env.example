# ── Server ─────────────────────────────────────────────────────────────────────
# Host and port for the FastAPI server
HOST=0.0.0.0
PORT=8000
# Enable debug logging and SQLAlchemy echo
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite database URL (aiosqlite async driver)
# Default stores in ./data/ relative to src/backend/
DATABASE_URL=sqlite+aiosqlite:///./data/arb_monitor.db

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Telegram Bot API token (from @BotFather)
# Leave empty to disable Telegram notifications
TELEGRAM_BOT_TOKEN=

# ── Exchange API Keys ──────────────────────────────────────────────────────────
# Most exchanges use public WebSocket feeds; API keys are optional.
# Only needed if you want authenticated endpoints (higher rate limits).

# Bithumb (optional — public WS does not require keys)
BITHUMB_API_KEY=
BITHUMB_API_SECRET=

# Upbit (optional — public WS does not require keys)
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# Coinone (optional — REST fallback may use token)
COINONE_ACCESS_TOKEN=

# Binance (optional — public WS does not require keys)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit (optional — public WS does not require keys)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── FX Rate Fallback ──────────────────────────────────────────────────────────
# ExchangeRate-API key for KRW/USD fallback when Upbit USDT ticker is stale
# Get a free key at https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# ── Alert Thresholds (percent) ────────────────────────────────────────────────
# Default severity tier thresholds
INFO_THRESHOLD_PCT=1.0
WARNING_THRESHOLD_PCT=2.0
CRITICAL_THRESHOLD_PCT=3.0

# ── Staleness ─────────────────────────────────────────────────────────────────
# Price data considered stale after this many seconds without update
STALENESS_THRESHOLD_SECONDS=5
