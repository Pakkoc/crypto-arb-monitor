# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/arb_monitor.db

# ── Telegram ────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Exchange API Keys ───────────────────────────────────────────────────────────
BITHUMB_API_KEY=
BITHUMB_API_SECRET=

UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

COINONE_ACCESS_TOKEN=

BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── KRW/USD FX Rate Fallback ────────────────────────────────────────────────────
# Used when Upbit KRW-USDT WebSocket is unavailable
EXCHANGERATE_API_KEY=

# ── Alert Thresholds (percentage, absolute) ──────────────────────────────────────
INFO_THRESHOLD_PCT=1.0
WARNING_THRESHOLD_PCT=2.0
CRITICAL_THRESHOLD_PCT=3.0

# ── Staleness Detection ─────────────────────────────────────────────────────────
# Prices older than this many seconds are marked stale
STALENESS_THRESHOLD_SECONDS=5

# ── Server ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
